# YourLocalJared Configuration
# Copy this to .env and adjust as needed

# Document directory
# YLJ_DOCUMENTS_DIR=./documents

# Qdrant (local file storage, no Docker needed)
# YLJ_QDRANT_PATH=./qdrant_data
# YLJ_COLLECTION_NAME=documents

# Embedding model
# YLJ_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# LLM — change this if Mistral 7B is too large for your machine
# YLJ_LLM_MODEL=mistralai/Mistral-7B-Instruct-v0.3

# RAG settings
# YLJ_CHUNK_SIZE=500
# YLJ_CHUNK_OVERLAP=50
# YLJ_TOP_K=5

# Server
# YLJ_SERVER_HOST=0.0.0.0
# YLJ_SERVER_PORT=8000
